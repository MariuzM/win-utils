<Application
    x:Class="WinOsUtils.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:WinOsUtils.Converters"
    xmlns:controls="clr-namespace:WinOsUtils.Controls"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!--  Declared once here; previously re-declared in every page's UserControl.Resources.  -->
            <conv:StateToGlyphConverter x:Key="StateGlyph" />
            <conv:StateToBrushConverter x:Key="StateBrush" />

            <!--
                Semantic status colours. Kept as literal brushes because StateToBrushConverter
                resolves them by name at runtime via Application.Current.TryFindResource.
                These read acceptably against both the light and dark WPF-UI palettes.
            -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#5FD068" />
            <SolidColorBrush x:Key="CautionBrush" Color="#F2C94C" />
            <SolidColorBrush x:Key="CriticalBrush" Color="#FF6B6B" />

            <!--
                Neutral fallback used by StateToBrushConverter for the NotApplicable state.
                Deliberately a literal brush, NOT <StaticResource x:Key=.../> aliasing a WPF-UI
                theme key — as a dictionary entry that form silently swallows the preceding
                entry (it ate CriticalBrush), leaving the converter to fall back to grey.
            -->
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0" />

            <!--
                Text styles now bind to WPF-UI theme keys with DynamicResource so that switching
                between light and dark actually repaints. The old hardcoded StaticResource brushes
                could never do this.
            -->
            <Style x:Key="TitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>
            <Style x:Key="BodyText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="BodyStrongText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>
            <Style x:Key="CaptionText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="GlyphText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>

            <!--
                Card container, rebased onto WPF-UI surface brushes.
                ui:Card exists, but keeping a Border style avoids rewriting every layout that
                relies on Border-specific properties.
            -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <!--  Implicit style: every ToolCard picks this up without an explicit Style=.  -->
            <Style TargetType="{x:Type controls:ToolCard}">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type controls:ToolCard}">
                            <Border
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18,16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="22"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Symbol="{TemplateBinding Icon}" />
                                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{TemplateBinding Title}" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="12"
                                                TextWrapping="Wrap"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{TemplateBinding Status}" />
                                        </StackPanel>
                                    </Grid>
                                    <ContentPresenter Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
