<ui:FluentWindow
    x:Class="WinUtils.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:WinUtils.Views"
    Title="WinUtils"
    Width="1040"
    Height="720"
    MinWidth="840"
    MinHeight="560"
    FontFamily="Segoe UI Variable, Segoe UI"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="WinUtils"
            ShowMaximize="True"
            ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Wrench24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            OpenPaneLength="230"
            PaneDisplayMode="Left">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="System"
                    TargetPageType="{x:Type views:SystemPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Key24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Debloat"
                    TargetPageType="{x:Type views:DebloatPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Privacy"
                    TargetPageType="{x:Type views:PrivacyPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="LockClosed24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Performance"
                    TargetPageType="{x:Type views:PerformancePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="TopSpeed24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Apps"
                    TargetPageType="{x:Type views:AppsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Apps24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="Personalization"
                    TargetPageType="{x:Type views:PersonalizationPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Grid24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
