<UserControl
    x:Class="WinUtils.Views.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:WinUtils.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" controls:WheelScroll.Proportional="True">
        <StackPanel Margin="32,20,32,32" MaxWidth="920" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource TitleText}" Text="Apps" />
            <TextBlock
                Margin="0,4,0,20"
                Style="{StaticResource CaptionText}"
                FontSize="14"
                Text="Remove what you don't want and install what you do." />

            <controls:ToolCard
                x:Name="InventoryCard"
                Icon="AppsList24"
                Title="Installed apps"
                Status="Not scanned">
                <StackPanel>
                    <TextBlock
                        Style="{StaticResource CaptionText}"
                        FontSize="13"
                        Margin="0,0,0,14"
                        Text="Scan every uninstallable app — classic desktop programs and Store apps that show in Start. Tick the ones you want gone and uninstall them in one pass. Each app's leftover folders and registry keys are detected up front and removed too." />

                    <ui:InfoBar
                        Margin="0,0,0,14"
                        Severity="Warning"
                        IsClosable="False"
                        IsOpen="True"
                        Title="This permanently removes apps and their data"
                        Message="Uninstalling can't be undone. Leftover cleanup is best-effort and only touches folders and keys that clearly belong to the app — shared system locations are never deleted. Some installers run their own uninstaller window that may need a click; a few changes finish after a reboot." />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <ui:Button
                            x:Name="ScanButton"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon Search24}"
                            Content="Scan"
                            Click="OnScanClick" />
                        <ui:Button
                            x:Name="UninstallButton"
                            Margin="10,0,0,0"
                            Icon="{ui:SymbolIcon Delete24}"
                            Content="Uninstall selected"
                            IsEnabled="False"
                            Click="OnUninstallClick" />
                        <ui:ProgressRing
                            x:Name="BusyRing"
                            Width="22"
                            Height="22"
                            Margin="14,0,0,0"
                            IsIndeterminate="True"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <ui:InfoBar
                        x:Name="SummaryBar"
                        Margin="0,0,0,14"
                        IsClosable="False"
                        IsOpen="False" />

                    <StackPanel x:Name="ListCard" Visibility="Collapsed">
                        <Grid Margin="2,0,2,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="SelectAllCheck" Grid.Column="0" VerticalAlignment="Center" Click="OnSelectAllClick" Content="Select all" />
                            <TextBlock x:Name="SelectedCountText" Grid.Column="2" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Text="" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Margin="2,0,2,2" />

                        <ItemsControl x:Name="ResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                            Click="OnItemCheckClick" />
                                        <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource BodyStrongText}" Text="{Binding Name}" />
                                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,2,0,0" Text="{Binding Detail}" />
                                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,2,0,0" FontSize="11" Opacity="0.8" Text="{Binding LeftoverSummary}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Text="{Binding SourceLabel}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </controls:ToolCard>

            <controls:ToolCard
                x:Name="BrowserCard"
                Icon="Globe24"
                Title="Install a browser"
                Status="Chrome, Brave or Firefox">
                <StackPanel>
                    <TextBlock
                        Style="{StaticResource CaptionText}"
                        FontSize="13"
                        Margin="0,0,0,14"
                        Text="Choose one, then install it with the Windows Package Manager." />

                    <RadioButton x:Name="ChromeOption" GroupName="browser" IsChecked="True" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStrongText}" Text="Google Chrome" />
                            <TextBlock x:Name="ChromeCaption" Style="{StaticResource CaptionText}" Margin="0,2,0,0" Text="" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="BraveOption" GroupName="browser" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStrongText}" Text="Brave" />
                            <TextBlock x:Name="BraveCaption" Style="{StaticResource CaptionText}" Margin="0,2,0,0" Text="" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="FirefoxOption" GroupName="browser" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStrongText}" Text="Mozilla Firefox" />
                            <TextBlock x:Name="FirefoxCaption" Style="{StaticResource CaptionText}" Margin="0,2,0,0" Text="" />
                        </StackPanel>
                    </RadioButton>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,14">
                        <ui:Button
                            x:Name="InstallButton"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon ArrowDownload24}"
                            Content="Install selected browser"
                            Click="OnInstallClick" />
                        <ui:ProgressRing
                            x:Name="InstallBusyRing"
                            Width="22"
                            Height="22"
                            Margin="14,0,0,0"
                            IsIndeterminate="True"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <ui:InfoBar
                        x:Name="InstallResultBar"
                        IsClosable="False"
                        IsOpen="False" />
                </StackPanel>
            </controls:ToolCard>

            <controls:ToolCard
                x:Name="ClaudeCard"
                Icon="ArrowDownload24"
                Title="Claude Code CLI"
                Status="Not scanned">
                <controls:RemediationSection
                    x:Name="ClaudeSection"
                    Description="Install the Claude Code CLI to %USERPROFILE%\.local\bin and add it to your user PATH."
                    ApplyLabel="Install &amp; configure"
                    CompliantTitle="Claude Code is installed"
                    CompliantMessage="The CLI is present and on your PATH." />
            </controls:ToolCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
