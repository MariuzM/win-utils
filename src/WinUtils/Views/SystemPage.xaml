<UserControl
    x:Class="WinUtils.Views.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:WinUtils.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" controls:WheelScroll.Proportional="True">
        <StackPanel Margin="32,20,32,32" MaxWidth="920" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource TitleText}" Text="System" />
            <TextBlock
                Margin="0,4,0,20"
                Style="{StaticResource CaptionText}"
                FontSize="14"
                Text="Account and sign-in behaviour for this PC." />

            <controls:ToolCard
                x:Name="AutoLogonCard"
                Icon="Key24"
                Title="Passwordless sign-in"
                Status="Reading…">
                <StackPanel>
                    <TextBlock
                        Style="{StaticResource CaptionText}"
                        FontSize="13"
                        Margin="0,0,0,14"
                        Text="Sign in to Windows 11 automatically at startup, without typing your password." />

                    <ui:InfoBar
                        Margin="0,0,0,16"
                        Severity="Warning"
                        IsClosable="False"
                        IsOpen="True"
                        Title="Before you enable this"
                        Message="Automatic sign-in means anyone with physical access to this PC boots straight into your account. Your password is stored encrypted as an LSA secret (the same method Sysinternals Autologon and netplwiz use) — but an administrator on this machine can still recover it. Only enable this on a device you physically trust." />

                    <TextBlock Style="{StaticResource CaptionText}" Text="User name" />
                    <ui:TextBox x:Name="UserNameBox" Margin="0,4,0,14" />

                    <TextBlock Style="{StaticResource CaptionText}" Text="Domain" />
                    <ui:TextBox x:Name="DomainBox" Margin="0,4,0,14" />

                    <TextBlock Style="{StaticResource CaptionText}" Text="Password" />
                    <ui:PasswordBox x:Name="PasswordInputBox" Margin="0,4,0,16" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:Button
                            x:Name="EnableButton"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon Checkmark24}"
                            Content="Enable auto sign-in"
                            Click="OnEnableClick" />
                        <ui:Button
                            x:Name="DisableButton"
                            Margin="10,0,0,0"
                            Content="Turn off"
                            Click="OnDisableClick" />
                    </StackPanel>

                    <ui:InfoBar
                        x:Name="ResultBar"
                        IsClosable="False"
                        IsOpen="False" />
                </StackPanel>
            </controls:ToolCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
